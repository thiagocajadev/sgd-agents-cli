#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

pattern='^(feat|fix|docs|audit|land|chore|refactor|test|perf)(\([^)]+\))?:\s'
first_line=$(head -n 1 "$1")

if ! echo "$first_line" | grep -qE "$pattern"; then
  echo "❌ Commit message must start with: feat|fix|docs|audit|land|chore|refactor|test|perf:"
  echo "Got: $first_line"
  exit 1
fi
