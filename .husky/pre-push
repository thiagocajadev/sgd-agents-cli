#!/usr/bin/env sh

# NVM Shim (Essential for projects Staff in Linux/NVM)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

# 1. Pre-push sanity check (tests must pass)
npm test

# 2. Narrative Guard (ensure everything is versioned before push)
node src/engine/bin/audit/check-narrative.mjs --pre-push
